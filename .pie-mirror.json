{
    "upstream": {
        "repo": "phpredis/phpredis",
        "type": "github"
    },
    "php_ext_name": "redis",
    "source_dir": "src/",
    "sync": {
        "prereleases": false,
        "initial-versions": 3
    },
    "build": {
        "enabled": true,
        "os": [
            "linux",
            "darwin"
        ],
        "arches": [
            "x86_64",
            "arm64"
        ],
        "php-version-constraints": [
            {
                "ext-versions": "<=6.1.0",
                "php-versions": ["8.2", "8.3"]
            },
            {
                "ext-versions": ">6.1.0 <=6.2.0",
                "php-versions": ["8.2", "8.3", "8.4"]
            },
            {
                "ext-versions": ">6.2.0",
                "php-versions": ["8.2", "8.3", "8.4", "8.5"]
            }
        ],
        "zts": [
            "nts",
            "ts"
        ],
        "build-path": "."
    }
}
